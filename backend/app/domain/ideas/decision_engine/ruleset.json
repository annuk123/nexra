    "growing market",
    "increasing demand",
    "emerging trend"
  ],

  "points_per_hit": 3,

  "default_score": 6,

  "max_score": 20
},

"founder_speed": {
  "speed_keywords": [
    "built",
    "launched",
    "prototype",
    "mvp",
    "users",
    "tested",
    "released"
  ],

  "points_per_hit": 4,

  "default_score": 5,

  "max_score": 20
}


