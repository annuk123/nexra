{
  "version": "1.2",
  "scoring_scale": {
    "min": 0,
    "max": 20,
    "default_floor": 4
  },

"market": {
  "intent": "Assess clarity, urgency, and validation of real market demand",

  "positive_keywords": [
    "saas",
    "api",
    "crm",
    "marketplace",
    "automation",
    "dashboard",
    "analytics",
    "platform",
    "tool",
    "software"
  ],

  "user_keywords": [
    "developers",
    "founders",
    "designers",
    "agencies",
    "teams",
    "businesses",
    "startups",
    "freelancers",
    "creators",
    "companies",
    "students",
    "engineers"
  ],

  "pain_keywords": [
    "slow",
    "manual",
    "time-consuming",
    "inefficient",
    "frustrating",
    "complex",
    "expensive",
    "error-prone",
    "waste time",
    "hard to"
  ],

  "validation_keywords": [
    "validated",
    "users",
    "customers",
    "paying",
    "revenue",
    "feedback",
    "tested",
    "pilot",
    "beta users",
    "early adopters"
  ],

  "generic_keywords": [
    "innovative",
    "revolutionary",
    "disruptive",
    "cutting-edge",
    "next-gen",
    "game-changing",
    "ai-powered",
    "blockchain-based",
    "web3",
    "ecosystem"
  ],

  "negative_keywords": [
    "idea stage",
    "just an idea",
    "experiment",
    "not validated",
    "exploring",
    "maybe",
    "potentially"
  ],

  "points": {
    "category_hit": 3,
    "user_hit": 4,
    "pain_hit": 4,
    "validation_hit": 5
  },

  "penalties": {
    "generic_penalty": 2,
    "negative_penalty": 3
  },

  "minimum_signal_requirements": {
    "category": 1,
    "user": 1
  },

  "default_score": 4,

  "max_score": 20,

  "severity_weight": 1.5,

  "confidence_weight": 1.3,

  "evidence_weight": 1.4,

  "is_blocking": true,

  "red_flags": {

    "generic_only": {
      "enabled": true,
      "count": 1,
      "message": "Idea relies on buzzwords without clear market or user definition"
    },

    "no_user_defined": {
      "enabled": true,
      "count": 1,
      "message": "Target user is not clearly defined"
    },

    "no_validation_signal": {
      "enabled": false,
      "count": 1,
      "message": "No validation or user feedback evidence detected"
    }

  },

  "metadata": {
    "dimension": "market",
    "philosophy": "Market pull is strongest predictor of startup success",
    "last_updated": "2026-02"
  }
},

  "founder_fit": {
    "intent": "Use problem articulation clarity as proxy for founder understanding",

    "problem_verbs": [
      "solve",
      "reduce",
      "eliminate",
      "automate",
      "simplify",
      "replace",
      "optimize"
    ],

    "problem_context_keywords": [
      "time",
      "cost",
      "manual",
      "inefficient",
      "slow",
      "error",
      "complex"
    ],

    "points": {
      "verb_hit": 4,
      "context_hit": 3
    },

    "default_score": 6,
    "max_score": 20,

    "red_flags": {
      "weak_problem_definition": {
        "enabled": true,
        "threshold": 0,
        "count": 2,
        "message": "Problem exists but is weakly or vaguely defined"
      }
    }
  },

  "execution": {
    "intent": "Estimate execution and regulatory risk for early-stage founders",

    "high_complexity_keywords": [
      "hardware",
      "medical",
      "biotech",
      "robot",
      "deep learning",
      "embedded",
      "semiconductor",
      "autonomous"
    ],

    "base_score": 16,
    "penalty_per_complexity": 5,

    "min_score": 0,
    "max_score": 20,

    "red_flags": {
      "high_execution_risk": {
        "enabled": true,
        "threshold_score": 8,
        "count": 1,
        "message": "High execution or regulatory complexity detected"
      }
    }
  },

  "moat": {
    "intent": "Evaluate defensibility and long-term differentiation",

    "defensibility_keywords": [
      "data",
      "network",
      "integration",
      "workflow",
      "community",
      "switching cost",
      "ecosystem"
    ],

    "points_per_hit": 4,

    "default_score": 6,
    "max_score": 20,

    "red_flags": {
      "no_moat": {
        "enabled": true,
        "count": 1,
        "message": "No clear moat or defensibility mentioned"
      }
    }
  },

  "revenue": {
    "intent": "Check monetization clarity and buyer realism",

    "monetization_keywords": [
      "b2b",
      "subscription",
      "pricing",
      "enterprise",
      "pay",
      "contract",
      "usage-based",
      "per seat",
      "license"
    ],

    "points_per_hit": 4,

    "default_score": 6,
    "max_score": 20,

    "red_flags": {
      "missing_revenue_model": {
        "enabled": true,
        "count": 2,
        "message": "Revenue model is unclear or missing"
      }
    }
  },

  "distribution": {
  "distribution_keywords": [
    "audience",
    "followers",
    "community",
    "newsletter",
    "users",
    "customers",
    "twitter",
